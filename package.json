{
  "name": "powerbid",
  "version": "0.1.0",
  "private": true,
  "description": "PowerBid — quotation & inquiry management on Cloudflare (Workers + D1 + R2)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml}\"",
    "db:generate": "pnpm --filter @powerbid/api db:generate",
    "db:migrate:local": "pnpm --filter @powerbid/api db:migrate:local",
    "db:migrate:remote": "pnpm --filter @powerbid/api db:migrate:remote",
    "db:seed:local": "pnpm --filter @powerbid/api db:seed:local",
    "deploy:api": "pnpm --filter @powerbid/api deploy",
    "deploy:web": "pnpm --filter @powerbid/web deploy"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
