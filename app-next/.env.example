BID_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# Legacy fallback still supported by code:
# POWERBID_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
JWT_SECRET=change-me-to-long-random-string
JWT_ISSUER=bid
SEED_KEY=bid-demo
APP_URL=http://localhost:3000

# Batch 4 dispatch (email/whatsapp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# WhatsApp provider (wa_me | twilio)
WHATSAPP_PROVIDER=wa_me
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Provider callback security
DISPATCH_WEBHOOK_SECRET=change-me
