{
  "name": "@powerbid/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply powerbid --local",
    "db:migrate:remote": "wrangler d1 migrations apply powerbid --remote",
    "db:migrate:staging": "wrangler d1 migrations apply powerbid-staging --remote --env staging",
    "db:migrate:prod": "wrangler d1 migrations apply powerbid --remote --env production",
    "db:seed:local": "tsx scripts/seed.ts --local",
    "db:seed:remote": "tsx scripts/seed.ts --remote"
  },
  "dependencies": {
    "@powerbid/shared": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.5",
    "jose": "^5.9.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241011.0",
    "@types/node": "^22.7.5",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "wrangler": "^3.80.0"
  }
}
